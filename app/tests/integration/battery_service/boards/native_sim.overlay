 *
 * Devicetree fragment for the battery_service integration test on
 * native_sim. Provides:
 *   - zephyr,adc-emul with one channel
 *   - voltage-divider node bound to that channel (matches the production
 *     /vbatt node consumed by app/src/battery_service.c)
 *   - gpio-emul + gpio-keys node providing the charge_status pin
 */

#include <zephyr/dt-bindings/adc/adc.h>

/ {
	gpio_emul_node: gpio_emul {
		compatible = "zephyr,gpio-emul";
		gpio-controller;
		#gpio-cells = <2>;
		status = "okay";
	};

	vbatt {
		compatible = "voltage-divider";
		status = "okay";
		io-channels = <&adc0 0>;
		output-ohms = <180000>;
		full-ohms = <(180000 + 1500000)>;
		power-on-sample-delay-us = <10000>;
	};

	charging {
		compatible = "gpio-keys";
		charge_status: charge_status {
			gpios = <&gpio_emul_node 17 0>;
			label = "Battery Charge Status";
		};
	};

	adc0: adc {
		compatible = "zephyr,adc-emul";
		nchannels = <1>;
		ref-internal-mv = <3300>;
		#io-channel-cells = <1>;
		status = "okay";

		#address-cells = <1>;
		#size-cells = <0>;

		channel@0 {
			reg = <0>;
			zephyr,gain = "ADC_GAIN_1";
			zephyr,reference = "ADC_REF_INTERNAL";
			zephyr,vref-mv = <3300>;
			zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
			zephyr,resolution = <12>;
		};
	};
};
